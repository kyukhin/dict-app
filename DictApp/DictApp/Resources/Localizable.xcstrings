    "support.email.bodyGreeting": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please describe the issue you encountered. The block below helps us reproduce it — feel free to edit anything you don't want to share."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опишите, пожалуйста, проблему, с которой вы столкнулись. Блок ниже помогает нам её воспроизвести — можете отредактировать или удалить всё, чем не хотите делиться."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Describe el problema que encontraste. El bloque de abajo nos ayuda a reproducirlo; puedes editar o eliminar cualquier dato que no quieras compartir."
          }
        }
      }
    },
