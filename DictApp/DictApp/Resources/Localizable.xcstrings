{
  "sourceLanguage": "en",
  "strings": {
    "about.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An open-source, offline-first dictionary application. All lookups are performed locally using SQLite FTS5 full-text search. No internet connection required."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Офлайн-словарь с открытым исходным кодом. Все запросы выполняются локально с помощью полнотекстового поиска SQLite FTS5. Подключение к интернету не требуется."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una aplicación de diccionario de código abierto que funciona sin conexión. Todas las búsquedas se realizan localmente mediante la búsqueda de texto completo SQLite FTS5. No se requiere conexión a internet."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تطبيق قاموس مفتوح المصدر يعمل دون اتصال بالإنترنت. تُجرى جميع عمليات البحث محليًا باستخدام بحث النص الكامل SQLite FTS5. لا يتطلب اتصالاً بالإنترنت."
          }
        }
      }
    },
    "about.section": {
