    "support.email.bodyGreeting": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please describe the issue you encountered. The block below helps us reproduce it — feel free to edit anything you don't want to share."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Опишите, пожалуйста, проблему, с которой вы столкнулись. Блок ниже помогает нам её воспроизвести — можете отредактировать или удалить всё, чем не хотите делиться."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Describe el problema que encontraste. El bloque de abajo nos ayuda a reproducirlo; puedes editar o eliminar cualquier dato que no quieras compartir."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرجى وصف المشكلة التي واجهتها. تساعدنا الكتلة أدناه على إعادة إنتاجها — يمكنك تعديل أو حذف أي شيء لا ترغب في مشاركته."
          }
        }
      }
    },
    "support.email.subject": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "LibreDict bug report"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сообщение об ошибке в LibreDict"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Informe de error de LibreDict"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بلاغ خطأ في LibreDict"
          }
        }
      }
    },
    "support.mailUnavailable.body.noAccount": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Mail account is set up on this device. Copy the address and send us a message from any mail client."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На этом устройстве не настроена учётная запись Mail. Скопируйте адрес и отправьте нам сообщение из любого почтового клиента."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay ninguna cuenta de Mail configurada en este dispositivo. Copia la dirección y envíanos un mensaje desde cualquier cliente de correo."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يوجد حساب بريد مُعدّ على هذا الجهاز. انسخ العنوان وأرسل لنا رسالة من أي تطبيق بريد."
          }
        }
      }
    },
    "support.mailUnavailable.body.noClient": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No mail client is installed on this device. Copy the support address and send us a message however you can."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На этом устройстве не установлен почтовый клиент. Скопируйте адрес поддержки и напишите нам любым удобным способом."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay ningún cliente de correo instalado en este dispositivo. Copia la dirección de soporte y envíanos un mensaje como puedas."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يوجد تطبيق بريد مثبّت على هذا الجهاز. انسخ عنوان الدعم وأرسل لنا رسالة بأي طريقة ممكنة."
          }
        }
      }
    },
